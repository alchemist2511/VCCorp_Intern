
PROJECT_NAME=tiki_de_pipeline
VIETNAM_TIMEZONE=Asia/Ho_Chi_Minh
PYTHON_VERSION=3.12

# =========================================================
# Airflow
# UI: http://localhost:8080
# =========================================================
AIRFLOW_BASE_IMAGE=apache/airflow:2.10.5-python3.12
AIRFLOW_IMAGE_NAME=tiki-airflow-py312:local
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_HOST_PORT=8080
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_airflow_secret_key
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Airflow metadata database
# Host access: localhost:5433
# Internal Docker access: postgres_airflow:5432
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_HOST_PORT=5433

# =========================================================
# PostgreSQL OLTP for project data
# Host access: localhost:5434
# Internal Docker access: postgres_oltp:5432
# =========================================================
APP_DB_USER=tiki_user
APP_DB_PASSWORD=tiki_password
APP_DB_NAME=tiki_oltp
APP_DB_HOST=postgres_oltp
APP_DB_PORT=5432
APP_DB_HOST_PORT=5434
APP_POSTGRES_CONN=postgresql+psycopg2://tiki_user:tiki_password@postgres_oltp:5432/tiki_oltp

# =========================================================
# MinIO object storage
# API:     http://localhost:9000
# Console: http://localhost:9001
# Internal Docker access: minio:9000
# =========================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_RAW=tiki-raw
MINIO_SECURE=false

# =========================================================
# Superset
# UI: http://localhost:8088
# =========================================================
SUPERSET_IMAGE=apache/superset:latest
SUPERSET_HOST_PORT=8088
SUPERSET_SECRET_KEY=change_me_superset_secret_key
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=User
SUPERSET_ADMIN_EMAIL=admin@example.com

# =========================================================
# pgAdmin
# UI: http://localhost:5050
# =========================================================
PGADMIN_HOST_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
